SERVER=your_server_here
PORT=3000

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
APP_NUMBER=your_twilio_number
YOUR_NUMBER=your_destination_number
TRANSFER_NUMBER=your_transfer_number

# AI services
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_MODEL_ID=eleven_turbo_v2
ELEVENLABS_VOICE_ID=XrExE9yKIg1WjnnlVkGX
ELEVENLABS_STT_MODEL_ID=scribe_v2_realtime
ELEVENLABS_STT_AUDIO_FORMAT=pcm_16000
ELEVENLABS_STT_SAMPLE_RATE=16000
ELEVENLABS_STT_COMMIT_STRATEGY=vad
ELEVENLABS_STT_VAD_THRESHOLD=0.4
ELEVENLABS_STT_VAD_SILENCE_THRESHOLD=0.6
ELEVENLABS_STT_MIN_SPEECH_MS=120
ELEVENLABS_STT_MIN_SILENCE_MS=120
ELEVENLABS_STT_MAX_RECONNECTS=3
ELEVENLABS_STT_RECONNECT_DELAY_SEC=0.5

# App behavior
LLM_SERVICE=openai
TTS_SERVICE=elevenlabs
RECORD_CALLS=false
SYSTEM_MESSAGE=You are a helpful phone assistant.
INITIAL_MESSAGE=Hello, this is an AI assistant calling.

# Performance tuning
TWILIO_CALL_THROTTLE_SEC=1.0
LLM_RESPONSE_BUDGET_SEC=0.45
INTERRUPT_DEBOUNCE_SEC=0.5
TRANSCRIPT_DUPLICATE_WINDOW_SEC=2.0
ASSISTANT_DUPLICATE_WINDOW_SEC=1.5
TRANSCRIPT_FLUSH_SEC=0.35

# Optional defaults
EMAIL_TOOL_DEFAULT=none
EMAIL_RECIPIENT_DEFAULT=
